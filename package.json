{
  "name": "arena-coop",
  "version": "0.1.0",
  "description": "Кооперативный браузерный слэшер 1-4 игрока. Авторитарный сервер + Three.js клиент.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:server\" \"npm:client\"",
    "server": "node server/index.js",
    "client": "vite --host",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "test": "node --test test/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "express": "^4.19.2",
    "three": "^0.160.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^10.7.0",
    "vite": "^5.2.0"
  }
}
